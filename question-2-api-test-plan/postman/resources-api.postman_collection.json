{
  "info": {
    "name": "Resources API (Open Finance Brasil v3.0.0)",
    "description": "Functional, contract, negative and deterministic-security checks for the Resources API (Recursos). Single endpoint: GET /open-banking/resources/v3/resources. Point {{baseUrl}} at the host, and provide {{accessToken}}, {{consentBToken}} and {{consentAResourceId}} via the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "resourceType", "value": "ACCOUNT,CREDIT_CARD_ACCOUNT,LOAN,FINANCING,UNARRANGED_ACCOUNT_OVERDRAFT,INVOICE_FINANCING,BANK_FIXED_INCOME,CREDIT_FIXED_INCOME,VARIABLE_INCOME,TREASURE_TITLE,FUND,EXCHANGE" },
    { "key": "resourceStatus", "value": "AVAILABLE,UNAVAILABLE,TEMPORARILY_UNAVAILABLE,PENDING_AUTHORISATION" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Inject the FAPI headers required by every Resources API call.",
          "const uuid = require('uuid');",
          "const interactionId = uuid.v4();",
          "pm.collectionVariables.set('interactionId', interactionId);",
          "pm.request.headers.upsert({ key: 'x-fapi-interaction-id', value: interactionId });",
          "pm.request.headers.upsert({ key: 'x-fapi-auth-date', value: new Date().toUTCString() });",
          "pm.request.headers.upsert({ key: 'x-fapi-customer-ip-address', value: '198.51.100.10' });",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "F-01 List resources - happy path",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": {
          "raw": "{{baseUrl}}/open-banking/resources/v3/resources?page-size=25",
          "host": [ "{{baseUrl}}" ],
          "path": [ "open-banking", "resources", "v3", "resources" ],
          "query": [ { "key": "page-size", "value": "25" } ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const validTypes = pm.collectionVariables.get('resourceType').split(',');",
              "const validStatus = pm.collectionVariables.get('resourceStatus').split(',');",
              "",
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('Content-Type is application/json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
              "pm.test('echoes x-fapi-interaction-id', () => pm.expect(pm.response.headers.get('x-fapi-interaction-id')).to.eql(pm.collectionVariables.get('interactionId')));",
              "",
              "const body = pm.response.json();",
              "pm.test('envelope has data, links, meta', () => {",
              "  pm.expect(body).to.have.property('data').that.is.an('array');",
              "  pm.expect(body).to.have.property('links');",
              "  pm.expect(body).to.have.property('meta');",
              "});",
              "pm.test('page-size honored', () => pm.expect(body.data.length).to.be.at.most(25));",
              "pm.test('meta counts are consistent', () => {",
              "  pm.expect(body.meta.totalRecords).to.be.a('number');",
              "  pm.expect(body.meta.totalPages).to.be.a('number');",
              "});",
              "pm.test('every resource matches the contract', () => {",
              "  body.data.forEach((r) => {",
              "    pm.expect(r.resourceId, 'resourceId').to.be.a('string').and.to.have.length.below(101);",
              "    pm.expect(validTypes, 'type').to.include(r.type);",
              "    pm.expect(validStatus, 'status').to.include(r.status);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "F-04 List resources - pagination links",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": {
          "raw": "{{baseUrl}}/open-banking/resources/v3/resources?page-size=1&page=1",
          "host": [ "{{baseUrl}}" ],
          "path": [ "open-banking", "resources", "v3", "resources" ],
          "query": [ { "key": "page-size", "value": "1" }, { "key": "page", "value": "1" } ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('at most one record returned', () => pm.expect(body.data.length).to.be.at.most(1));",
              "pm.test('self and first links present', () => {",
              "  pm.expect(body.links).to.have.property('self');",
              "  pm.expect(body.links).to.have.property('first');",
              "});",
              "pm.test('next link present when more pages exist', () => {",
              "  if (body.meta.totalPages > 1) { pm.expect(body.links.next, 'links.next').to.be.a('string'); }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "S-01 Consent isolation - token bound to another consent",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{consentBToken}}" } ],
        "url": {
          "raw": "{{baseUrl}}/open-banking/resources/v3/resources",
          "host": [ "{{baseUrl}}" ],
          "path": [ "open-banking", "resources", "v3", "resources" ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('returns only the resources of the bound consent', () => {",
              "  const ids = body.data.map((r) => r.resourceId);",
              "  pm.expect(ids, 'must not expose another consent resource').to.not.include(pm.environment.get('consentAResourceId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "E-01 Missing Authorization header",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/open-banking/resources/v3/resources",
          "host": [ "{{baseUrl}}" ],
          "path": [ "open-banking", "resources", "v3", "resources" ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    },
    {
      "name": "E-05 Missing x-fapi-interaction-id",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": {
          "raw": "{{baseUrl}}/open-banking/resources/v3/resources",
          "host": [ "{{baseUrl}}" ],
          "path": [ "open-banking", "resources", "v3", "resources" ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// undo the collection-level injection for this negative case",
              "pm.request.headers.remove('x-fapi-interaction-id');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('400 Bad Request', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "E-07 Unsupported Accept",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Accept", "value": "text/xml" }
        ],
        "url": {
          "raw": "{{baseUrl}}/open-banking/resources/v3/resources",
          "host": [ "{{baseUrl}}" ],
          "path": [ "open-banking", "resources", "v3", "resources" ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.request.headers.upsert({ key: 'Accept', value: 'text/xml' });"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('406 Not Acceptable', () => pm.response.to.have.status(406));"
            ]
          }
        }
      ]
    }
  ]
}
